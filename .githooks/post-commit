#!/usr/bin/env bash
# Git post-commit hook: deploy to staging automatically
# Logs are appended to .githooks/deploy.log

# avoid blocking git commit; run in background
(
  echo "[post-commit] Starting deploy: $(date)"
  npm run deploy:staging >> .githooks/deploy.log 2>&1
  echo "[post-commit] Deploy finished: $(date)"
) &

exit 0
